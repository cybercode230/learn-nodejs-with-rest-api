generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  role             Role      @default(GUEST)
  avatar           String?
  bio              String?
  createdAt        DateTime  @default(now())
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  updatedAt        DateTime  @default(now()) @updatedAt
  bookings         Booking[] @relation("GuestBookings")
  listings         Listing[] @relation("HostListings")
  profile          Profile?
}

model Profile {
  id          String  @id
  bio         String?
  phoneNumber String?
  address     String?
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Listing {
  id            String      @id
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  amenities     String[]
  rating        Float?
  createdAt     DateTime    @default(now())
  hostId        String
  updatedAt     DateTime    @updatedAt
  type          ListingType
  bookings      Booking[]
  host          User        @relation("HostListings", fields: [hostId], references: [id], onDelete: Cascade)
  tags          Tag[]       @relation("ListingToTag")
}

model Tag {
  id       String    @id
  name     String    @unique
  listings Listing[] @relation("ListingToTag")
}

model Booking {
  id         String        @id
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  guestId    String
  listingId  String
  guest      User          @relation("GuestBookings", fields: [guestId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
}


enum Role {
  HOST
  GUEST
  ADMIN
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
